      "name": "01. 鉴权与基建 (RESTful)",
      "item": [
        {
          "name": "1. 获取 Token (双重注入)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if(jsonData.token) {",
                  "    pm.environment.set(\"token\", jsonData.token);",
                  "    // MVC 接口认 zentaosid",
                  "    pm.environment.set(\"zentaosid\", jsonData.token);",
                  "    console.log(\"✅ Token 鉴权成功\");",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"account\": \"{{account}}\",\n    \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api.php/v1/tokens",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api.php",
                "v1",
                "tokens"
              ]
            }
          },
          "response": []
        },
