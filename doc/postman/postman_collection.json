        {
          "name": "通过中文名获取账号 (User Mapping)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "var targetRealName = pm.environment.get(\"real_name\"); // 从环境变量读取你想查的中文名",
                  "",
                  "if (jsonData.users && jsonData.users.length > 0) {",
                  "    // 在返回的列表中寻找真实姓名匹配的员工",
                  "    var matchedUser = jsonData.users.find(u => u.realname === targetRealName);",
                  "    ",
                  "    if (matchedUser) {",
                  "        // 如果找到了，自动把他的 account 存入环境变量",
                  "        pm.environment.set(\"target_account\", matchedUser.account);",
                  "        console.log(\"✅ 映射成功！中文名 [\" + targetRealName + \"] 对应的账号是: \" + matchedUser.account);",
                  "    } else {",
                  "        console.log(\"❌ 未找到匹配的中文名，请检查是否输入正确或调整分页 limit。\");",
                  "    }",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Token",
                "value": "{{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api.php/v1/users?limit=500",
              "host": [
