    {
      "name": "02. 我的地盘 (MVC上帝视角 - 请点击 Visualize 标签看中文)",
      "item": [
        {
          "name": "获取我的任务 (Tasks)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// 这里是处理中文转码和格式化的黑科技",
                  "var rawJson = pm.response.json();",
                  "if(rawJson.data) {",
                  "    try {",
                  "        var parsedData = JSON.parse(rawJson.data);",
                  "        var template = `",
                  "            <style>pre { background: #f4f4f4; padding: 15px; border-radius: 8px; font-family: Consolas, monospace; overflow-x: auto; }</style>",
                  "            <h3>✅ MVC 数据已完美解析为中文：</h3>",
                  "            <pre>{{response}}</pre>",
                  "        `;",
                  "        pm.visualizer.set(template, {",
                  "            response: JSON.stringify(parsedData, null, 4)",
                  "        });",
                  "    } catch(e) { console.log(\"解析失败\", e); }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "zentaosid",
                "value": "{{zentaosid}}",
                "description": "MVC接口核心鉴权头"
              }
            ],
            "url": {
              "raw": "{{base_url}}/my-task-assignedTo-0-id_desc-0-100-1.json",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "my-task-assignedTo-0-id_desc-0-100-1.json"
              ]
            }
          },
          "response": []
        },
